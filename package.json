{
  "name": "ctrace-audit",
  "displayName": "Ctrace Audit",
  "description": "Integration for Ctrace CLI Audit Tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ctrace-sidebar-view",
          "title": "Ctrace Audit",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "ctrace-sidebar-view": [
        {
          "type": "webview",
          "id": "ctrace-audit-view",
          "name": "Audit Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "ctrace.runAnalysis",
        "title": "Run Analysis"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run copy-lucide && tsc -p ./",
    "watch": "npm run copy-lucide && tsc -watch -p ./",
    "copy-lucide": "node -e \"require('fs').copyFileSync('node_modules/lucide/dist/umd/lucide.min.js', 'media/lucide.min.js')\""
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "lucide": "^0.575.0",
    "typescript": "^5.1.3"
  }
}
